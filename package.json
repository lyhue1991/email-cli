{
  "name": "@lyhue1991/email-cli",
  "version": "0.1.0",
  "description": "NPX 命令行邮件工具，支持 IMAP 收取和 SMTP 发送邮件",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "email": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "email": "node dist/index.js",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "email",
    "cli",
    "imap",
    "smtp",
    "nodemailer",
    "imapflow"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lyhue1991/email-cli.git"
  },
  "homepage": "https://github.com/lyhue1991/email-cli#readme",
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/lyhue1991/email-cli/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@types/turndown": "^5.0.6",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.3",
    "commander": "^12.0.0",
    "crypto-js": "^4.2.0",
    "imapflow": "^1.0.152",
    "inquirer": "^9.2.12",
    "mailparser": "^3.9.4",
    "nodemailer": "^6.9.8",
    "turndown": "^7.2.2"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.1",
    "@types/inquirer": "^9.0.9",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^6.4.23",
    "typescript": "^5.3.0",
    "vitest": "^3.2.4"
  }
}
